NODE_ENV=development

API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000
TRUST_PROXY_HOPS=0
WEB_APP_URL=http://localhost:3000

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=vale
DATABASE_PASSWORD=vale
DATABASE_NAME=vale_project

JWT_ACCESS_SECRET=dev-access-secret-change-before-production
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=15

LEGAL_TERMS_VERSION=terms-2026-07-24
LEGAL_PRIVACY_VERSION=privacy-2026-07-24
LEGAL_GUIDELINES_VERSION=guidelines-2026-07-24

# O provider log é permitido apenas fora de produção.
EMAIL_PROVIDER=log
EMAIL_FROM=no-reply@local.vale.test
# Para produção, use EMAIL_PROVIDER=http e configure ambos:
# EMAIL_HTTP_ENDPOINT=https://provider.example/send
# EMAIL_HTTP_TOKEN=troque-pelo-token-do-provider

# Opcionais e somente para bootstrap local/desenvolvimento:
# SEED_ADMIN_EMAIL=admin@local.vale.test
# SEED_ADMIN_PASSWORD=troque-esta-senha-local

NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
