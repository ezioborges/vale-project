{
  "name": "vale-project",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "corepack pnpm --parallel --recursive dev",
    "build": "corepack pnpm --recursive build",
    "lint": "corepack pnpm --recursive lint",
    "test": "corepack pnpm --recursive test",
    "test:integration": "corepack pnpm --filter @vale/api test:integration",
    "typecheck": "corepack pnpm --recursive typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,yml,yaml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,css,yml,yaml,md}\"",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@next/eslint-plugin-next": "^16.2.9",
    "eslint": "^9.29.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  }
}
